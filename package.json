{
  "name": "ai-lookbook-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "server": "npm --prefix backend run dev",
    "api:start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-lookbook-api.ps1",
    "api:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-lookbook-api.ps1",
    "api:restart": "npm run api:stop && npm run api:start",
    "api:install-startup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-lookbook-api-startup.ps1",
    "api:remove-startup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\uninstall-lookbook-api-startup.ps1",
    "api:open-firewall": "powershell -ExecutionPolicy Bypass -File .\\scripts\\open-lookbook-api-firewall.ps1",
    "api:close-firewall": "powershell -ExecutionPolicy Bypass -File .\\scripts\\close-lookbook-api-firewall.ps1",
    "build:android:configured": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-configured-android.ps1",
    "build:android:profile": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-configured-android-from-profile.ps1",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~53.0.11",
    "expo-asset": "~11.1.7",
    "expo-file-system": "~18.1.11",
    "expo-image-picker": "~16.1.4",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^22.15.30",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
