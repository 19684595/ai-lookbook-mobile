APP_DOMAIN=api.seudominio.com
LETSENCRYPT_EMAIL=seu-email@seudominio.com

NODE_ENV=production
PORT=8787
DATA_DIR=/app/data

# Use "mock" while testing the server, "openai" for OpenAI as the default provider,
# or "piapi" for PiAPI/Kling renderings.
LOOKBOOK_PROVIDER=mock

# Optional: leave empty if the app will send the user's OpenAI key in the settings screen.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RENDER_IMAGES=true

PIAPI_API_KEY=
PIAPI_POLL_INTERVAL_MS=4000
PIAPI_MAX_POLL_ATTEMPTS=30
PIAPI_TEMPORARY_HOST=cloudinary

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lookbook-temporary

SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tryon-temp
SUPABASE_STORAGE_PATH_PREFIX=temporary
