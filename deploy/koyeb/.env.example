NODE_ENV=production
PORT=8787
DATA_DIR=/app/data

# Use piapi for image rendering by default. The app can still request OpenAI
# per call when the user saves an OpenAI key in the AI connection card.
LOOKBOOK_PROVIDER=piapi

PIAPI_API_KEY=sua_chave_piapi
PIAPI_POLL_INTERVAL_MS=4000
PIAPI_MAX_POLL_ATTEMPTS=30
PIAPI_TEMPORARY_HOST=cloudinary

CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret
CLOUDINARY_FOLDER=temporary

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SECRET_KEY=sua_secret_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
SUPABASE_STORAGE_BUCKET=tryon-temp
SUPABASE_STORAGE_PATH_PREFIX=temporary

# Optional server-side OpenAI fallback.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RENDER_IMAGES=false
